{
  "name": "browser-e2e-test",
  "main": "worker.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "browser": { "binding": "BROWSER" },
  "worker_loaders": [{ "binding": "LOADER" }],
  "durable_objects": {
    "bindings": [
      {
        "name": "BrowserTestAgent",
        "class_name": "BrowserTestAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["BrowserTestAgent"]
    }
  ]
}
